{
  "name": "@bunny.net/monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run packages/cli/src/index.ts",
    "ny": "bun run packages/cli/src/index.ts",
    "build": "bun build packages/cli/src/index.ts --compile --outfile bunny",
    "typecheck": "bun run tsc --noEmit",
    "api:generate": "bun run --filter @bunny.net/api generate",
    "api:update": "bun run --filter @bunny.net/api update-specs"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
